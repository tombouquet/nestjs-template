{
  "name": "nestjs-template",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev email:dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "prettier": "^3.4.2",
    "turbo": "^2.7.5"
  },
  "packageManager": "bun@1.3.6",
  "engines": {
    "node": "24"
  },
  "volta": {
    "node": "24.14.0"
  }
}
