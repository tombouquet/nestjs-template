{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "tags": [
          "App"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "check",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The Health Check is successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "info": {
                      "type": "object",
                      "example": {
                        "database": {
                          "status": "up"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      },
                      "nullable": true
                    },
                    "error": {
                      "type": "object",
                      "example": {},
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      },
                      "nullable": true
                    },
                    "details": {
                      "type": "object",
                      "example": {
                        "database": {
                          "status": "up"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      }
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "The Health Check is not successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "info": {
                      "type": "object",
                      "example": {
                        "database": {
                          "status": "up"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      },
                      "nullable": true
                    },
                    "error": {
                      "type": "object",
                      "example": {
                        "redis": {
                          "status": "down",
                          "message": "Could not connect"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      },
                      "nullable": true
                    },
                    "details": {
                      "type": "object",
                      "example": {
                        "database": {
                          "status": "up"
                        },
                        "redis": {
                          "status": "down",
                          "message": "Could not connect"
                        }
                      },
                      "additionalProperties": {
                        "type": "object",
                        "required": [
                          "status"
                        ],
                        "properties": {
                          "status": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": true
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Health"
        ]
      }
    },
    "/email/test": {
      "post": {
        "description": "Sends a test email with custom HTML/text content. Only available in development mode.",
        "operationId": "testEmail",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendEmailDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Test email sent successfully"
          },
          "403": {
            "description": "Endpoint only available in development mode"
          }
        },
        "summary": "Send a test email (development only)",
        "tags": [
          "Email Testing"
        ]
      }
    },
    "/email/test/template": {
      "post": {
        "description": "Sends a test email using a React email template. Only available in development mode.",
        "operationId": "testTemplateEmail",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TestTemplateEmailDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Test template email sent successfully"
          },
          "403": {
            "description": "Endpoint only available in development mode"
          }
        },
        "summary": "Send a test template email (development only)",
        "tags": [
          "Email Testing"
        ]
      }
    },
    "/auth/register": {
      "post": {
        "operationId": "register",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User successfully registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              }
            }
          },
          "409": {
            "description": "User with this email already exists"
          }
        },
        "summary": "Register a new user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User successfully logged in",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Invalid email or password"
          }
        },
        "summary": "Login with email and password",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/me": {
      "get": {
        "operationId": "me",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Current user information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get current authenticated user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/files/upload": {
      "post": {
        "operationId": "uploadFile",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The file to upload"
                  },
                  "folder": {
                    "type": "string",
                    "description": "Optional folder path for organization"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "File uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid file or file too large"
          }
        },
        "summary": "Upload a file",
        "tags": [
          "files"
        ]
      }
    },
    "/files": {
      "get": {
        "operationId": "listFiles",
        "parameters": [],
        "responses": {
          "200": {
            "description": "List of all files",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FileResponseDto"
                  }
                }
              }
            }
          }
        },
        "summary": "List all files",
        "tags": [
          "files"
        ]
      }
    },
    "/files/{id}": {
      "get": {
        "operationId": "getFile",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File metadata with signed URL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "File not found"
          }
        },
        "summary": "Get file metadata and signed URL",
        "tags": [
          "files"
        ]
      },
      "delete": {
        "operationId": "deleteFile",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          },
          "204": {
            "description": "File deleted successfully"
          },
          "404": {
            "description": "File not found"
          }
        },
        "summary": "Delete a file",
        "tags": [
          "files"
        ]
      }
    },
    "/files/{id}/download": {
      "get": {
        "operationId": "downloadFile",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File content stream"
          },
          "404": {
            "description": "File not found"
          }
        },
        "summary": "Download file content",
        "tags": [
          "files"
        ]
      }
    }
  },
  "info": {
    "title": "NestJS Template API",
    "description": "This is the API for the NestJS Template project.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "NestJS Template",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "schemas": {
      "SendEmailDto": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string",
            "format": "email",
            "example": "user@example.com",
            "description": "Recipient email address"
          },
          "subject": {
            "type": "string",
            "example": "Welcome to our service",
            "description": "Email subject"
          },
          "text": {
            "type": "string",
            "example": "This is a plain text email body",
            "description": "Plain text email body"
          },
          "html": {
            "type": "string",
            "example": "<h1>This is an HTML email body</h1>",
            "description": "HTML email body"
          }
        },
        "required": [
          "to",
          "subject"
        ]
      },
      "TestTemplateEmailDto": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string",
            "format": "email",
            "example": "test@example.com",
            "description": "Recipient email address"
          },
          "templateName": {
            "type": "string",
            "example": "welcome",
            "description": "Template name to use",
            "enum": [
              "welcome",
              "password-reset"
            ]
          },
          "subject": {
            "type": "string",
            "example": "Test Email",
            "description": "Email subject"
          },
          "name": {
            "type": "string",
            "example": "John Doe",
            "description": "Name for welcome template"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com",
            "description": "Email for welcome template"
          },
          "resetLink": {
            "type": "string",
            "example": "https://example.com/reset-password?token=abc123",
            "description": "Reset link for password-reset template"
          },
          "expiresIn": {
            "type": "string",
            "example": "1 hour",
            "description": "Expiration time for password-reset template"
          }
        },
        "required": [
          "to",
          "templateName",
          "subject"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "User email address",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "description": "User password (minimum 8 characters)",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID",
            "example": "0d237300-7123-42dc-92c8-c2bcc57d394e"
          },
          "email": {
            "type": "string",
            "description": "User email address",
            "example": "user@example.com"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "admin"
              ]
            },
            "description": "User roles",
            "example": [
              "admin"
            ]
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "Created at date"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "description": "Updated at date"
          }
        },
        "required": [
          "id",
          "email",
          "roles",
          "createdAt",
          "updatedAt"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT access token",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "user": {
            "description": "User information",
            "allOf": [
              {
                "$ref": "#/components/schemas/UserResponseDto"
              }
            ]
          }
        },
        "required": [
          "accessToken",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "User password",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "FileResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the file",
            "example": "0d237300-7123-42dc-92c8-c2bcc57d394e"
          },
          "originalName": {
            "type": "string",
            "description": "Original filename as uploaded",
            "example": "document.pdf"
          },
          "mimeType": {
            "type": "string",
            "description": "MIME type of the file",
            "example": "application/pdf"
          },
          "size": {
            "type": "number",
            "description": "File size in bytes",
            "example": 1024
          },
          "storageKey": {
            "type": "string",
            "description": "Storage key/path in the storage backend",
            "example": "uploads/2024/01/abc123-document.pdf"
          },
          "bucket": {
            "type": "string",
            "description": "Storage bucket name",
            "example": "local-files"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "description": "Created at date",
            "example": "2024-01-15T10:30:00.000Z"
          },
          "url": {
            "type": "string",
            "description": "Signed URL for temporary access (when requested)",
            "example": "https://storage.example.com/file?signature=..."
          }
        },
        "required": [
          "id",
          "originalName",
          "mimeType",
          "size",
          "storageKey",
          "bucket",
          "createdAt"
        ]
      }
    }
  }
}